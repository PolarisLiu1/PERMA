# Required by evaluation.py (OpenAI client + model name)
CHAT_MODEL=gpt-4o-mini
CHAT_MODEL_API_KEY=your_chat_model_api_key
CHAT_MODEL_BASE_URL=https://api.openai.com/v1

# Optional by selected memory backend (--mem_frame)
MEM0_API_KEY=your_mem0_api_key
SUPERMEMORY_API_KEY=your_supermemory_api_key
MEMOBASE_PROJECT_URL=your_memobase_project_url
MEMOBASE_API_KEY=your_memobase_api_key
MEMOS_URL=http://localhost:8000
MEMOS_ONLINE_URL=https://your-memos-online-endpoint
MEMOS_KEY=your_memos_key

# Optional runtime settings
SEARCH_MODE=fast
TZ=Asia/Shanghai
